# Environment variables template

# ===== BASE DE DATOS =====
DATABASE_URL="file:./dev.db"
POSTGRES_PRISMA_URL="postgres://user:pass@host/db?pgbouncer=true&connect_timeout=15&sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://user:pass@host/db?sslmode=require"

# ===== BACKEND =====
NEXT_PUBLIC_BACKEND_URL="http://localhost:4000"
EMAIL="tu-email@ejemplo.com"

# ===== AUTENTICACIÓN JWT =====
# Contraseña maestra para login único (cámbiala por una segura)
MASTER_PASSWORD="change-me-to-a-secure-password"

# Secret para firmar JWT (genera uno aleatorio fuerte)
# Puedes generar uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-random-secret-key"

# Expiración del token JWT
# Ejemplos: 30d (30 días), 7d, 1h, 15m
JWT_EXPIRES_IN="30d"

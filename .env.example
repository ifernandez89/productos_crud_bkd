# Environment variables template

# ===== BASE DE DATOS =====
DATABASE_URL="file:./dev.db"
POSTGRES_PRISMA_URL="postgres://user:pass@host/db?pgbouncer=true&connect_timeout=15&sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://user:pass@host/db?sslmode=require"

# ===== BACKEND =====
NEXT_PUBLIC_BACKEND_URL="http://localhost:4000"
EMAIL="tu-email@ejemplo.com"

# ===== AUTENTICACIÓN JWT =====
# Contraseña maestra para login único (cámbiala por una segura)
MASTER_PASSWORD="change-me-to-a-secure-password"

# Secret para firmar JWT (genera uno aleatorio fuerte)
# Puedes generar uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-random-secret-key"

# Expiración del token JWT
# Ejemplos: 30d (30 días), 7d, 1h, 15m
JWT_EXPIRES_IN="30d"

# ===== MODELOS OLLAMA =====
# Modelo general / conversacional
OLLAMA_MODEL_NAME="llama3.2:3b"

# Modelo clasificador de intents (rápido, razonamiento — phi4-mini-reasoning)
OLLAMA_MODEL_TEST2_NAME="phi4-mini-reasoning:latest"

# Modelo técnico / experto (código, análisis — qwen3:4b)
OLLAMA_MODEL_TEST3_NAME="qwen3:4b"

# ===== GOOGLE WORKSPACE (OAuth) =====
# Crear credenciales en: console.cloud.google.com → APIs & Services → Credentials
# Activar: Calendar API, Gmail API, Drive API
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:4000/api/jarbees/google/callback"

# ===== YOUTUBE DATA API v3 =====
# Crear API Key en: console.cloud.google.com → APIs & Services → Credentials
# Activar: YouTube Data API v3
YOUTUBE_API_KEY="your-youtube-api-key"

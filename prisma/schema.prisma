generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════════════════════
// LEGACY MODELS (mantener temporalmente para compatibilidad)
// ══════════════════════════════════════════════════════════════════════════════

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  price       Float
  image       String?
  stock       Int
  isFeatured  Boolean?
  isOnSale    Boolean?
  isNew       Boolean?
  createdAT   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  marca       String
}

model Pregunta {
  id           Int      @id @default(autoincrement())
  texto        String
  respuesta    String
  estado       String   @default("success")
  errorMessage String?
  errorStatus  Int?
  createdAt    DateTime @default(now())
}

// ══════════════════════════════════════════════════════════════════════════════
// JARVIS ARCHITECTURE — 5-Layer Memory System
// ══════════════════════════════════════════════════════════════════════════════

// ── 1) PERFIL DE USUARIO ──────────────────────────────────────────────────────
// Jarvis debe conocer a su usuario

model UserProfile {
  id          Int      @id @default(autoincrement())
  name        String?
  timezone    String   @default("America/Argentina/Buenos_Aires")
  country     String   @default("Argentina")
  language    String   @default("es-AR")
  preferences String?  // JSON serializado
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  credentials UserCredential[]
}

// ── 1.1) CREDENCIALES DE USUARIO ──────────────────────────────────────────────
// Guarda tokens de acceso para integraciones (ej. Google Calendar, Drive, etc.)

model UserCredential {
  id           Int         @id @default(autoincrement())
  userProfileId Int
  provider     String      // "google", "microsoft", etc.
  accessToken  String
  refreshToken String?
  expiryDate   BigInt?     // timestamp de vencimiento
  scope        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  userProfile  UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, provider])
  @@index([provider])
}

// ── 2) MEMORIA PERMANENTE ─────────────────────────────────────────────────────
// Lo que diferencia Jarvis de ChatGPT: recuerda hechos sobre ti
// NO es key-value rígido, sino memoria semántica natural

model Memory {
  id           Int            @id @default(autoincrement())
  content      String         // "Ignacio trabaja con NestJS", "Prefiere TypeScript"
  category     String         // "preference", "fact", "context", "skill", "experience"
  importance   Int            @default(1) // 1-10, para rankear recuperación
  lastAccessed DateTime?      // tracking de uso para priorización
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  chunks       MemoryChunk[]

  @@index([category])
  @@index([importance])
  @@index([lastAccessed])
}

// ── 2.1) CHUNKS DE MEMORIA CON EMBEDDINGS ────────────────────────────────────
// Búsqueda semántica con pgvector

model MemoryChunk {
  id          Int                        @id @default(autoincrement())
  memoryId    Int
  content     String
  embeddingId String?                     // legacy: referencia a vector store externo
  embedding   Unsupported("vector(1024)")? // pgvector: búsqueda semántica nativa (bge-m3)
  memory      Memory  @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@index([embeddingId])
}

// ── 3) HISTORIAL CONVERSACIONAL ──────────────────────────────────────────────
// Reemplaza Pregunta con un sistema de sesiones

model ConversationMessage {
  id        Int      @id @default(autoincrement())
  sessionId String   // UUID de sesión, permite múltiples conversaciones
  role      String   // "user" | "assistant" | "system" | "tool"
  content   String
  metadata  String?  // JSON serializado: { model, tokens, latency, toolCalls, etc }
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

// ── 3.1) RESÚMENES DE SESIÓN ─────────────────────────────────────────────────
// Los agentes modernos NO envían 100 mensajes al modelo
// Envían resúmenes progresivos

model SessionSummary {
  id        Int      @id @default(autoincrement())
  sessionId String   @unique
  summary   String   // "Se habló de pgvector, diseño de Jarvis, NestJS"
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([sessionId])
}

// ── 4) CONOCIMIENTO (RAG) ─────────────────────────────────────────────────────
// Documentos estructurados que Jarvis puede consultar

model KnowledgeSource {
  id        Int        @id @default(autoincrement())
  name      String
  type      String     // "pdf", "markdown", "web", "notion", "github", "postgres", "api"
  url       String?    // URL o path
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  documents Document[]

  @@index([type])
  @@index([active])
}

// ── 4.1) COLECCIONES ─────────────────────────────────────────────────────────
// Agrupa documentos en colecciones temáticas (Programación, Astronomía, etc.)

model Collection {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  description String?
  color       String?              // "#4F46E5" — color de UI
  icon        String?              // emoji o nombre de ícono
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  documents   CollectionDocument[]

  @@index([name])
}

// Tabla pivote N:M entre Collection y Document
model CollectionDocument {
  id           Int        @id @default(autoincrement())
  collectionId Int
  documentId   Int
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  document     Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([collectionId, documentId])
  @@index([collectionId])
  @@index([documentId])
}

model Document {
  id          Int                  @id @default(autoincrement())
  sourceId    Int?                 // relación con KnowledgeSource
  title       String
  content     String
  category    String?              // "tech", "personal", "reference", "api-doc"
  source      String?              // legacy: URL, file path, manual
  status      String               @default("not_indexed") // "not_indexed" | "indexing" | "ready"
  timesUsed   Int                  @default(0)  // cuántas veces fue recuperado
  lastUsed    DateTime?            // última vez que se usó en RAG
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  chunks      Chunk[]
  knowledgeSource KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  collections CollectionDocument[]

  @@index([category])
  @@index([status])
  @@index([sourceId])
  @@index([timesUsed])
  @@index([lastUsed])
}

// ── 5) CHUNKS VECTORIALES ─────────────────────────────────────────────────────
// Fragmentos embeddables para búsqueda semántica con pgvector

model Chunk {
  id          Int                         @id @default(autoincrement())
  documentId  Int
  content     String
  embeddingId String?                     // legacy: referencia a vector store externo
  embedding   Unsupported("vector(1024)")? // pgvector: búsqueda semántica nativa (bge-m3)
  metadata    String?                     // JSON serializado: { page, section, language, etc }
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([embeddingId])
}

// ── 6) PLANNER (TAREAS) ───────────────────────────────────────────────────────
// Jarvis puede descomponer objetivos complejos en pasos

model Task {
  id        Int        @id @default(autoincrement())
  sessionId String?    // relacionar con conversación si aplica
  objective String
  status    String     @default("pending") // "pending" | "in_progress" | "completed" | "failed"
  priority  String?    @default("normal") // "low" | "normal" | "high" | "critical"
  category  String?    // "compras" | "trabajo" | "personal" | "tecnologia" | etc.
  project   String?    // "JarBees" | "Casa" | "Trabajo" | etc.
  result    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  steps     TaskStep[]

  @@index([status])
  @@index([sessionId])
  @@index([priority])
  @@index([category])
  @@index([project])
}

// ── 6.1) PASOS DE EJECUCIÓN ──────────────────────────────────────────────────
// Cada tarea se descompone en pasos ejecutables

model TaskStep {
  id          Int      @id @default(autoincrement())
  taskId      Int
  stepNumber  Int      // orden de ejecución
  description String   // "Buscar documentación de Ollama"
  result      String?  // resultado del paso
  status      String   @default("pending") // "pending" | "in_progress" | "completed" | "failed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([status])
}

// ── 7) FEEDBACK ───────────────────────────────────────────────────────────────
// Aprender de aciertos y errores

model Feedback {
  id        Int      @id @default(autoincrement())
  sessionId String?
  question  String
  answer    String
  score     Int      // 1-5 stars, o -1/+1 thumbs
  comment   String?
  createdAt DateTime @default(now())

  @@index([score])
  @@index([sessionId])
}

// ══════════════════════════════════════════════════════════════════════════════
// AGENT INFRASTRUCTURE — Tool Registry + Observability
// ══════════════════════════════════════════════════════════════════════════════

// ── 8) REGISTRO DE TOOLS ──────────────────────────────────────────────────────
// Tools dinámicamente registradas en vez de hardcoded

model Tool {
  id          Int      @id @default(autoincrement())
  name        String   @unique // "weather", "calendar", "rag", "memory", "search"
  description String
  category    String   // "external_api", "database", "llm", "system"
  enabled     Boolean  @default(true)
  config      String?  // JSON serializado
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@index([category])
}

// ── 9) OBSERVABILIDAD ─────────────────────────────────────────────────────────
// Métricas de ejecución del agente

model AgentRun {
  id         Int      @id @default(autoincrement())
  sessionId  String?
  question   String
  answer     String?
  toolsUsed  String?  // JSON serializado: ["weather", "rag", "memory"]
  modelUsed  String   // "llama3.2:3b", "qwen3.5:8b"
  provider   String   // "ollama", "openrouter", "openai"
  durationMs Int      // latencia total
  tokensUsed Int?     // tokens consumidos
  success    Boolean  @default(true)
  errorMsg   String?
  createdAt  DateTime @default(now())

  @@index([success])
  @@index([modelUsed])
  @@index([provider])
  @@index([createdAt])
}

// ══════════════════════════════════════════════════════════════════════════════
// WEB SCRAPING & KNOWLEDGE ACQUISITION LAYER
// ══════════════════════════════════════════════════════════════════════════════

// ── 10) FUENTES CONFIABLES (JarBees v2) ───────────────────────────────────────
// Catálogo de fuentes priorizadas por categoría con TTL y keywords semánticas

model Source {
  id                Int            @id @default(autoincrement())
  name              String         // "TyC Sports", "Farmacity", "Familia Bercomat"
  urlBase           String         // "https://www.tycsports.com"
  category          String         // "deportes", "salud", "ferreteria", "electronica"
  priority          Int            @default(5) // 1-10, mayor = más prioritario
  ttlHours          Int            @default(6) // TTL en horas para contenido de esta fuente
  active            Boolean        @default(true)
  
  // ── SEMÁNTICA: keywords para matching sin scraping ───────────────────────
  keywords          String         @default("[]") // JSON serializado: ["medicamentos", "recetas", "salud"]
  
  // ── CAPABILIDADES: qué operaciones están habilitadas ──────────────────────
  scrapeEnabled     Boolean        @default(true)  // ¿se puede scrapear?
  embeddingEnabled  Boolean        @default(false) // ¿tiene embeddings vectoriales?
  
  // ── METRICS: tracking de eficiencia ───────────────────────────────────────
  lastScraped       DateTime?      // última vez que se scrapeó
  lastEmbedding     DateTime?      // última vez que se generó embedding
  successRate       Float          @default(1.0) // % de scraping exitoso (0.0-1.0)
  avgResponseTimeMs Int?           // tiempo promedio de respuesta
  cacheHits         Int            @default(0) // cuántas veces se usó desde caché
  
  // ── CONFIGURACIÓN ─────────────────────────────────────────────────────────
  scrapingConfig    String?        // JSON serializado
  embeddingConfig   String?        // JSON serializado
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  pages             ScrapedPage[]
  
  @@unique([urlBase])
  @@index([category])
  @@index([active])
  @@index([priority])
}

// ── 11) PÁGINAS SCRAPEADAS ───────────────────────────────────────────────────
// Cache inteligente de contenido web con soporte para embeddings

model ScrapedPage {
  id              Int              @id @default(autoincrement())
  sourceId        Int
  url             String           // URL completa
  title           String?
  contentHash     String           // hash SHA-256 del contenido para detectar cambios
  scrapedAt       DateTime         @default(now())
  publishedAt     DateTime?        // fecha de publicación del contenido
  expiresAt       DateTime         // scrapedAt + source.ttlHours
  status          String           @default("valid") // "valid" | "expired" | "failed"
  cacheHits       Int              @default(0) // cuántas veces se usó desde caché
  lastAccessedAt  DateTime?        // última vez que se sirvió desde caché
  embeddingId     String?          // referencia a embedding vectorial (cuando se active pgvector)
  source          Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  content         ScrapedContent?

  @@unique([url])
  @@index([sourceId])
  @@index([expiresAt])
  @@index([status])
  @@index([scrapedAt])
  @@index([cacheHits])
  @@index([embeddingId])
}

// ── 12) CONTENIDO CRUDO ───────────────────────────────────────────────────────
// Almacenamiento del contenido crudo + procesado

model ScrapedContent {
  id           Int          @id @default(autoincrement())
  pageId       Int          @unique
  htmlRaw      String?      // HTML crudo (opcional, solo para páginas importantes)
  textExtracted String      // Texto limpio extraído
  jsonExtracted String?      // JSON serializado
  metadata     String?       // JSON serializado: { wordCount, headlines, links, images, etc }
  page         ScrapedPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

// ── 13) CONSULTAS (ANALYTICS) ─────────────────────────────────────────────────
// Tracking de patrones de uso para optimización

model Query {
  id            Int      @id @default(autoincrement())
  question      String
  category      String   // detectada por intent router
  sourcesUsed   String?  // JSON serializado: ["tycsports", "espn"]
  cacheHit      Boolean  @default(false) // si se sirvió desde caché
  responseTimeMs Int     // latencia total
  createdAt     DateTime @default(now())

  @@index([category])
  @@index([cacheHit])
  @@index([createdAt])
}

// ── 10) KNOWLEDGE EVOLUTION ──────────────────────────────────────────────────
// El diferencial real de JarBees: cómo evoluciona el pensamiento del usuario

model TopicSnapshot {
  id         Int      @id @default(autoincrement())
  topic      String   // "Qwen", "NestJS", "arquitectura backend"
  conclusion String   // qué se aprendió / concluyó en ese momento
  tags       String   @default("[]") // JSON serializado: ["llm", "rendimiento", "local"]
  sessionId  String?
  createdAt  DateTime @default(now())

  @@index([topic])
  @@index([createdAt])
  @@index([sessionId])
}

// ── 14) BALANCE ENERGÉTICO (JarBees v2.1) ────────────────────────────────────
// Registro histórico del balance de energía del usuario en 7 dimensiones.

model BalanceSession {
  id                  Int             @id @default(autoincrement())
  createdAt           DateTime        @default(now())
  completedAt         DateTime?
  type                String          @default("manual") // "manual" | "periodic"
  astrologicalContext Json?           // natal chart and transits context
  summary             String?
  scoreGeneral        Float?
  nextRecommendedAt   DateTime?
  answers             BalanceAnswer[]
  reports             BalanceReport[]
}

model BalanceAnswer {
  id         Int            @id @default(autoincrement())
  sessionId  Int
  question   String
  answer     String
  metadata   Json?
  session    BalanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model BalanceReport {
  id                 Int            @id @default(autoincrement())
  sessionId          Int
  analysis           String         // JSON text containing strengths, blind spot, etc.
  recommendations    String         // JSON text containing focus action, reflection questions, seed
  energyDistribution Json           // JSON score map: {"expansion": X, "disciplina": Y, ...}
  createdAt          DateTime       @default(now())
  session            BalanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
